APP_ENV=development

# PostgreSQL
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
DATABASE_URL=

# pgAdmin
PGADMIN_DEFAULT_EMAIL=
PGADMIN_DEFAULT_PASSWORD=
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000
SPACY_MODEL=es_core_news_md
TRANSLATION_PROVIDER=google
# Optional: OpenAI API key for slang-aware translation fallback.
# When set, words Google cannot translate (returns the original word) are automatically
# retried with GPT using a music/lyrics-aware prompt. Set TRANSLATION_PROVIDER=openai
# to use OpenAI exclusively.
OPENAI_API_KEY=

# JWT signing secret — required, no default. App will not start without it.
# Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Cloudflare R2 — object storage for user avatars.
# Create a bucket, enable public access, then generate an API token with Object Read & Write.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=https://pub-xxx.r2.dev